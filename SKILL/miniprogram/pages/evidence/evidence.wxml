<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item" bindtap="showFilter">
      <text>筛选</text>
      <image class="filter-icon" src="/images/filter.png"/>
    </view>
    <view class="filter-tags" wx:if="{{filterTags.length > 0}}">
      <text class="active-filter" wx:for="{{filterTags}}" wx:key="*this">{{item}}</text>
      <text class="clear-filter" bindtap="clearFilter">清除</text>
    </view>
  </view>

  <!-- 证据列表 -->
  <scroll-view class="evidence-list" scroll-y refresher-enabled bindrefresherrefresh="onPullDownRefresh">
    <view class="evidence-cards">
      <view 
        class="evidence-card"
        wx:for="{{tasks}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="goToDetail"
        bindlongpress="enterMultiSelect"
      >
        <!-- 多选框 -->
        <view class="checkbox" wx:if="{{isMultiSelect}}" catchtap="toggleSelect" data-id="{{item._id}}">
          <view class="checkbox-inner {{selectedTasks.includes(item._id) ? 'checked' : ''}}"></view>
        </view>
        
        <!-- 图标 -->
        <view class="evidence-icon">{{item.tagIcon}}</view>
        
        <!-- 内容 -->
        <view class="evidence-content">
          <text class="evidence-text">{{item.shortContent}}</text>
          <view class="evidence-meta">
            <view class="evidence-tags">
              <text class="tag-mini" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
            </view>
            <text class="evidence-time">{{item.minutes}}分钟</text>
          </view>
        </view>
        
        <!-- 证据数量 -->
        <view class="evidence-count">
          <text class="count-badge">{{item.evidenceCount}}</text>
          <text class="count-label">证据</text>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{tasks.length === 0 && !loading}}">
      <image class="empty-icon" src="/images/empty.png" mode="aspectFit"/>
      <text>暂无带证据的记录</text>
    </view>
    
    <!-- 加载更多 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && tasks.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <!-- 多选操作栏 -->
  <view class="multi-select-bar" wx:if="{{isMultiSelect}}">
    <view class="select-info">
      <text>已选择 {{selectedTasks.length}} 项</text>
      <text class="cancel-btn" bindtap="exitMultiSelect">取消</text>
    </view>
    <view class="select-actions">
      <view class="action-btn" bindtap="batchExport">
        <image src="/images/export.png"/>
        <text>导出PDF</text>
      </view>
    </view>
  </view>
</view>

<!-- 筛选面板 -->
<view class="modal {{showFilterPanel ? 'show' : ''}}" bindtap="closeFilter">
  <view class="filter-panel" catchtap="preventClose">
    <view class="panel-header">
      <text class="panel-title">筛选标签</text>
      <image class="close-btn" src="/images/close.png" bindtap="closeFilter"/>
    </view>
    
    <scroll-view class="panel-body" scroll-y>
      <view class="filter-options">
        <view 
          class="option {{filterTags.includes(item.name) ? 'active' : ''}}"
          wx:for="{{allTags}}"
          wx:key="id"
          data-tag="{{item}}"
          bindtap="toggleTagFilter"
        >{{item.name}}</view>
      </view>
    </scroll-view>
    
    <view class="panel-footer">
      <button class="clear-btn" bindtap="clearFilter">清除筛选</button>
      <button class="confirm-btn" bindtap="closeFilter">确定</button>
    </view>
  </view>
</view>
