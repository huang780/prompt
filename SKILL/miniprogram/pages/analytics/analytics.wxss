.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 日期选择 */
.date-selector {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
}

.date-option {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: var(--bg-secondary);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.date-option.active {
  background: var(--primary);
  color: white;
}

/* 统计概览 */
.stats-overview {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 饼图 */
.pie-chart {
  padding: 30rpx;
}

.chart-container {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.pie-wrapper {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pie {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
}

.pie-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.legend-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.legend-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 排行榜 */
.rank-list {
  padding: 30rpx;
}

.rank-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
}

.rank-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 20rpx;
}

.rank-number.top {
  background: var(--primary);
  color: white;
}

.rank-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.rank-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.rank-stats {
  text-align: right;
}

.rank-minutes {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.rank-percentage {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.rank-empty {
  text-align: center;
  padding: 60rpx;
  color: var(--text-tertiary);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: var(--primary);
  color: white;
}

.action-btn.secondary {
  background: white;
  color: var(--text-primary);
  border: 2rpx solid var(--border);
}

.action-btn image {
  width: 36rpx;
  height: 36rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  padding: 20rpx;
  max-height: 60vh;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid var(--border);
}

.selected-count {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.generate-btn {
  padding: 20rpx 40rpx;
  background: var(--primary);
  color: white;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.generate-btn::after {
  border: none;
}

/* 证据列表 */
.evidence-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.evidence-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border);
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.checkbox.checked::after {
  content: '';
  width: 20rpx;
  height: 12rpx;
  border-left: 4rpx solid white;
  border-bottom: 4rpx solid white;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

.evidence-content {
  flex: 1;
}

.evidence-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.evidence-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.evidence-tag {
  padding: 4rpx 12rpx;
  background: white;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.evidence-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
